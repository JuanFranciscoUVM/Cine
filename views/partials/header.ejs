<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <div class="dashboard-container">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <i class="fa-solid fa-film"></i>
        <span>CineVision</span>
      </div>
      <nav class="sidebar-nav">
        <% if (typeof user !== 'undefined' && user) { %>
          <a href="/" class="<%= title === 'CineVision Dashboard' ? 'active' : '' %>"><i class="fa-solid fa-house"></i> Dashboard</a>

          <% if (user.rol === 'admin' || user.rol === 'empleado' || user.rol === 'cliente') { %>
            <a href="/peliculas" class="<%= title === 'Películas' ? 'active' : '' %>"><i class="fa-solid fa-video"></i> Películas</a>
          <% } %>

          <% if (user.rol === 'admin' || user.rol === 'empleado') { %>
            <a href="/salas" class="<%= title === 'Salas' ? 'active' : '' %>"><i class="fa-solid fa-couch"></i> Salas</a>
          <% } %>

          <% if (user.rol === 'admin' || user.rol === 'empleado' || user.rol === 'cliente') { %>
            <a href="/funciones" class="<%= title === 'Funciones' ? 'active' : '' %>"><i class="fa-solid fa-calendar-alt"></i> Funciones</a>
          <% } %>

          <% if (user.rol === 'cliente' || user.rol === 'empleado') { %>
            <a href="/reservaciones" class="<%= title === 'Reservaciones' ? 'active' : '' %>"><i class="fa-solid fa-ticket-simple"></i> Reservaciones</a>
          <% } %>

          <a href="/permisos" class="<%= title === 'Roles y permisos' ? 'active' : '' %>"><i class="fa-solid fa-shield-halved"></i> Permisos</a>
          <a href="/logout"><i class="fa-solid fa-right-from-bracket"></i> Cerrar sesión</a>
        <% } else { %>
          <a href="/login" class="<%= title === 'Iniciar sesión' ? 'active' : '' %>"><i class="fa-solid fa-right-to-bracket"></i> Login</a>
          <a href="/registro" class="<%= title === 'Registro' ? 'active' : '' %>"><i class="fa-solid fa-user-plus"></i> Registro</a>
        <% } %>
      </nav>
    </aside>
    <main class="main-content">
      <header class="top-header">
        <h1><%= title %></h1>
        <% if (typeof user !== 'undefined' && user) { %>
          <div class="user-badge">
            <i class="fa-solid fa-user"></i>
            <%= user.nombre %> · <span><%= user.rol %></span>
          </div>
        <% } else { %>
          <div class="user-badge muted">Debe iniciar sesión</div>
        <% } %>
      </header>
      <div class="content-wrapper">
