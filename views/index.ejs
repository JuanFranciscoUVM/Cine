<%- include('partials/header') %>

<div class="stats-grid">
  <div class="stat-card">
    <div class="value">Hola, <%= user.nombre %></div>
    <div class="label">Rol: <%= user.rol %></div>
  </div>
</div>

<div class="card">
  <h2>Su panel</h2>
  <% if (user.rol === 'admin') { %>
    <p style="color: var(--text-muted); line-height: 1.6;">
      Como <strong>admin</strong> gestiona el catálogo del cine:
      <br><br>
      - Crear, editar y eliminar <a href="/peliculas" style="color:var(--primary)">películas</a><br>
      - Crear y editar <a href="/salas" style="color:var(--primary)">salas</a><br>
      - Consultar la cartelera de <a href="/funciones" style="color:var(--primary)">funciones</a> (sin programarlas)
    </p>
  <% } else if (user.rol === 'empleado') { %>
    <p style="color: var(--text-muted); line-height: 1.6;">
      Como <strong>empleado</strong> opera la programación y el control de boletería:
      <br><br>
      - Consultar <a href="/peliculas" style="color:var(--primary)">películas</a> y <a href="/salas" style="color:var(--primary)">salas</a><br>
      - Programar y ajustar <a href="/funciones" style="color:var(--primary)">funciones</a><br>
      - Controlar <a href="/reservaciones" style="color:var(--primary)">reservaciones</a> (eliminar / últimas 5)
    </p>
  <% } else if (user.rol === 'cliente') { %>
    <p style="color: var(--text-muted); line-height: 1.6;">
      Como <strong>cliente</strong> puede reservar entradas:
      <br><br>
      - Ver el catálogo de <a href="/peliculas" style="color:var(--primary)">películas</a><br>
      - Ver la cartelera de <a href="/funciones" style="color:var(--primary)">funciones</a><br>
      - Crear y modificar sus <a href="/reservaciones" style="color:var(--primary)">reservaciones</a>
    </p>
  <% } %>
  <p style="margin-top: 1rem; color: var(--text-muted);">
    Detalle completo en <a href="/permisos" style="color: var(--primary);">Roles y permisos</a>.
  </p>
</div>

<%- include('partials/footer') %>
