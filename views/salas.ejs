<%- include('partials/header') %>

<% if (typeof user !== 'undefined' && user && user.rol === 'admin') { %>
<div class="card">
  <h2>Ingresar Nueva Sala</h2>
  <p style="color:var(--text-muted);margin-bottom:1rem;">Solo rol <strong>admin</strong></p>
  <form onsubmit="crear(event)">
    <div class="form-group">
      <label>Nombre de Sala</label>
      <input type="text" id="nombre" required>
    </div>
    <div class="form-group">
      <label>Capacidad</label>
      <input type="number" id="capacidad" required>
    </div>
    <button type="submit" class="btn"><i class="fa-solid fa-plus"></i> Añadir Sala</button>
  </form>
</div>
<% } else { %>
<div class="card">
  <p style="color: var(--text-muted);">Solo lectura (empleado). Crear / modificar salas requiere rol <strong>admin</strong>.</p>
</div>
<% } %>

<div class="card">
  <h2>Listado de Salas</h2>
  <table>
    <thead>
      <tr>
        <th>ID</th>
        <th>Nombre</th>
        <th>Capacidad</th>
      </tr>
    </thead>
    <tbody>
      <% salas.forEach(function(s) { %>
        <tr>
          <td><%= s.id %></td>
          <td><strong><%= s.nombre %></strong></td>
          <td><%= s.capacidad %> personas</td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<script>
async function crear(e) {
  e.preventDefault();
  const body = {
    nombre: document.getElementById('nombre').value,
    capacidad: parseInt(document.getElementById('capacidad').value)
  };
  await apiRequest('/api/salas', {
    method: 'POST',
    body: JSON.stringify(body)
  });
}
</script>

<%- include('partials/footer') %>
