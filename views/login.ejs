<%- include('partials/header') %>

<div class="card" style="max-width: 420px; margin: 0 auto;">
  <h2>Iniciar sesión</h2>
  <p style="color: var(--text-muted); margin-bottom: 1.25rem;">
    Acceda con su cuenta. La sesión se gestiona con JWT.
  </p>

  <% if (error) { %>
    <div class="alert-warn"><%= error %></div>
  <% } %>

  <form method="POST" action="/login">
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" required placeholder="admin@cine.com">
    </div>
    <div class="form-group">
      <label>Contraseña</label>
      <input type="password" name="password" required placeholder="••••••">
    </div>
    <button type="submit" class="btn"><i class="fa-solid fa-right-to-bracket"></i> Entrar</button>
  </form>

  <p style="margin-top: 1.25rem; color: var(--text-muted); font-size: 0.9rem;">
    ¿No tiene cuenta? <a href="/registro" style="color: var(--primary);">Regístrese</a>
  </p>
</div>

<%- include('partials/footer') %>
